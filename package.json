    "member:attendance": "ts-node scripts/gymMemberService.ts attendance",
    "member:payments": "ts-node scripts/gymMemberService.ts payments",
    "payment:verify": "ts-node scripts/paymentVerificationService.ts verify-pending",
    "payment:revenue": "ts-node scripts/paymentVerificationService.ts revenue",
    "payment:by-type": "ts-node scripts/paymentVerificationService.ts revenue-by-type"
